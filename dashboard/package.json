{
  "name": "umich-balloons-dashboard-worker",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "typecheck": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply dashboard-db --local",

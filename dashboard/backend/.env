# .env file

# PostgreSQL / PostGIS
POSTGRES_DB=gisdb
POSTGRES_USERNAME=gisuser
POSTGRES_PASSWORD=a_very_secure_password # CHANGE THIS!
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis Configuration
REDIS_URL=redis://redis:6379
REDIS_QUEUE_DB=0
REDIS_CACHE_DB=1

# APRS config
APRS_IS_HOST=noam.aprs2.net
APRS_IS_PORT=14580
APRS_IS_CALLSIGN=N0CALL
APRS_IS_PASSWORD=-1
# APRS_FILTER=p/KF8ABL/KD8CJT  s//#O
APRS_FILTER=p/KF8ABL/KD8CJT


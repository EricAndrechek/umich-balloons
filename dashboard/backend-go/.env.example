# Server
LISTEN_ADDR=:8080

# SondeHub
SONDEHUB_API_URL=https://api.v2.sondehub.org
SOFTWARE_NAME=umich-balloons
SOFTWARE_VERSION=2.0.0

# Set to "true" to send dev-flagged data (SondeHub accepts but discards)
DEV_MODE=true

# Batch upload interval in seconds
UPLOAD_INTERVAL=2

# Iridium IMEI -> Callsign mapping
# Either a JSON file path:
# CALLSIGN_MAP_FILE=/path/to/callsigns.json
# Or inline (comma-separated IMEI:CALLSIGN pairs):
# CALLSIGN_MAP=300234068765430:KF8ABL-11,300234068765431:KF8ABL-12

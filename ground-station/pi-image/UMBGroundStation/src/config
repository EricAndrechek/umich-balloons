export DIST_NAME=UMBGroundStation
export DIST_VERSION=0.0.1
export MODULES="base(raspicam, network, disable-services(gui(fullpageos), usage-statistics))"

# if set will enlarge root parition prior to build by provided size in MB
export BASE_IMAGE_ENLARGEROOT=2000

# if set will resize root partition on image after build to minimum size + 
# provided size in MB
export BASE_IMAGE_RESIZEROOT=200
export GUI_STARTUP_SCRIPT=/opt/custompios/scripts/run_onepageos

export RPI_IMAGER_NAME="${DIST_NAME}"
export RPI_IMAGER_DESCRIPTION="Umich-Balloons Ground Station OS Image"
export RPI_IMAGER_ICON="https://raw.githubusercontent.com/EricAndrechek/Umich-Balloons/ground-station/pi-image/static/rpi-imager-UMBGroundStation.png"

export USAGE_STATISTICS_URL=https://fullpageos-tracking.gnethomelinux.com

